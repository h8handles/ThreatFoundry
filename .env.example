DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
DJANGO_TIME_ZONE=UTC
INTEL_LOCAL_TIME_ZONE=America/New_York

OTX_API_KEY=
THREATFOX_API_KEY=
VIRUSTOTAL_API_KEY=
URLHAUS_API_KEY=
ABUSEIPDB_API_KEY=
SHODAN_API_KEY=
NVD_API_KEY=

THREATFOX_ENABLED=true
URLHAUS_ENABLED=true
ALIENVAULT_ENABLED=true
VIRUSTOTAL_ENABLED=true
ABUSEIPDB_ENABLED=false
SHODAN_ENABLED=false
NVD_ENABLED=false

INTEL_REFRESH_SCHEDULE=0 2 * * *
INTEL_REFRESH_DEFAULT_SINCE=24h
INTEL_REFRESH_TIMEOUT=30
INTEL_REFRESH_VIRUSTOTAL_LIMIT=25
INTEL_REFRESH_VIRUSTOTAL_THROTTLE_SECONDS=16
INTEL_CHAT_PROVIDER=hybrid
INTEL_CHAT_MAX_CONTEXT_RECORDS=60
INTEL_CHAT_N8N_WEBHOOK_URL=
INTEL_CHAT_N8N_TIMEOUT=20
INTEL_CHAT_N8N_BEARER_TOKEN=

